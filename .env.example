# Application
APP_NAME=CustomerIntent
APP_ENV=development
APP_VERSION=1.0.0
DEBUG=true

# API
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# ML Config
MODEL_VERSION=v1
DEFAULT_MODEL=baseline
CONFIDENCE_THRESHOLD=0.6
MAX_TEXT_LENGTH=512

# MLflow
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=customer-intent-classification

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
